                <mxCell id="p2_prod_entry" value="ENTRY MODULES Y CONTROLLERS&#xa;appointments/, doctors/, profiles/, offices/, specialties/, metrics/, audit/&#xa;health.controller.ts y producer.controller.ts&#xa;GET publicos permanecen en Producer; los comandos protegidos se validan antes de enviar a RabbitMQ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
