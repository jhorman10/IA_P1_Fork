                <mxCell id="p2_prod_domain" value="DOMAIN, READ MODELS Y PORTS&#xa;domain/commands -&gt; cancel-appointment.command.ts, complete-appointment.command.ts&#xa;domain/models -&gt; appointment-view, doctor-view, profile-view&#xa;domain/ports -&gt; inbound + outbound contracts&#xa;domain/value-objects -&gt; id-card.vo.ts, patient-name.vo.ts&#xa;CQRS: Producer sirve lecturas y valida precondiciones antes de publicar comandos" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
