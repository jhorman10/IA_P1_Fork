                <mxCell id="p2_cons_bg" value="CONSUMER - NestJS Worker / WRITE SIDE / DOMINIO" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;align=center;verticalAlign=top;" parent="1" vertex="1">
