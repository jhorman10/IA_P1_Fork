                <mxCell id="p2_fe_delta" value="DELTA EXPLICITO EN FE&#xa;[NUEVO S003] AssignmentNotification, QueuePositionBadge, DoctorInfo, QueuePosition domain, queue-position service&#xa;[MOD S003] WaitingAppointmentCard y CalledAppointmentCard muestran posicion, doctor y office&#xa;[NUEVO S004] LoginForm, RoleGate, ProfileFormModal, AuthProvider, pages protegidas de acceso operativo&#xa;[MOD S004] el token Bearer pasa a llamadas protegidas y al operational websocket" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d9ead3;strokeColor=#82b366;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
