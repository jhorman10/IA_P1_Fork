                <mxCell id="p2_fe_present" value="PRESENTATION / APP ROUTER&#xa;/, /dashboard, /registration, /doctor/dashboard, /admin/dashboard, /admin/audit&#xa;[NUEVO S004] /login y /admin/profiles&#xa;Componentes: Navbar, AppointmentForm, AppointmentRegistrationForm, AppointmentCard, DoctorStatusCard, MetricsGrid, AuditLogTable" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
