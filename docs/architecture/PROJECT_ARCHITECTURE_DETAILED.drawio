    <diagram id="patterns-page" name="3. Patrones de Diseno y DDD SOLID">
        <mxGraphModel dx="1219" dy="738" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2600" pageHeight="1800" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="p3_title" value="PATRONES DE DISENO, DDD TACTICAL Y SOLID&#xa;Mapa explicito de donde aparece cada patron dentro del repo" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1f2937;strokeColor=#111827;fontColor=#ffffff;fontStyle=1;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="20" y="20" width="2560" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="p3_arch_hex" value="ARQUITECTURA HEXAGONAL&#xa;Consumer completo&#xa;Producer parcial con ports/adapters&#xa;Frontend simplificado con ports + adapters + composition root" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="40" y="120" width="600" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="p3_arch_event" value="EVENT-DRIVEN ARCHITECTURE&#xa;Producer publica en turnos_queue&#xa;Consumer procesa y notifica en turnos_notifications&#xa;RabbitMQ + DLQ + retry" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="670" y="120" width="600" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="p3_arch_cqrs" value="CQRS&#xa;Producer = read side + command gateway&#xa;Consumer = write side + dominio + side effects" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="1300" y="120" width="600" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="p3_arch_ddd" value="DDD TACTICAL&#xa;Entities, Value Objects, Domain Events, Error hierarchy, Read models, Branded types" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="1930" y="120" width="610" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="p3_l_title" value="PATRONES 1 A 9" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;align=center;" parent="1" vertex="1">
                    <mxGeometry x="40" y="310" width="1220" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="p3_r_title" value="PATRONES 10 A 18" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;align=center;" parent="1" vertex="1">
                    <mxGeometry x="1320" y="310" width="1220" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="p3_1" value="1. Repository&#xa;Appointment / Doctor / Office / Lock repositories&#xa;Consumer persistence + frontend repository abstraction" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="40" y="380" width="380" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="p3_2" value="2. Adapter&#xa;RabbitMQNotificationAdapter&#xa;FirebaseAuthAdapter&#xa;SocketIoAdapter / AuthenticatedSocketIoAdapter" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="460" y="380" width="380" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="p3_3" value="3. Decorator&#xa;event-dispatching-appointment-repository.decorator.ts&#xa;Publica Domain Events despues de save" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="880" y="380" width="380" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="p3_4" value="4. Factory&#xa;appointment.factory.ts&#xa;Crea entidades en estado inicial valido" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="40" y="560" width="380" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="p3_5" value="5. Observer / Domain Events&#xa;DomainEventBus + appointment-events.handler.ts + auto-assign.handler.ts&#xa;AppointmentRegisteredEvent / AppointmentAssignedEvent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="460" y="560" width="380" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="p3_6" value="6. Policy&#xa;consultation.policy.ts&#xa;Encapsula disponibilidad y reglas de asignacion" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="880" y="560" width="380" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="p3_7" value="7. Specification&#xa;appointment-query.specification.ts&#xa;ACTIVE_STATUSES y QUEUE_SORT_ORDER" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="40" y="740" width="380" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="p3_8" value="8. Command&#xa;register-appointment.command.ts&#xa;cancel-appointment.command.ts&#xa;complete-appointment.command.ts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="460" y="740" width="380" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="p3_9" value="9. Data Mapper&#xa;appointment.mapper.ts / doctor.mapper.ts&#xa;domain to persistence / response DTO" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="880" y="740" width="380" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="p3_10" value="10. Builder&#xa;mongoose-query.builder.ts&#xa;Specification -&gt; Mongo filter" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="1320" y="380" width="380" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="p3_11" value="11. Composite&#xa;compound-broadcaster.ts&#xa;AppointmentsGateway + OperationalAppointmentsGateway" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="1740" y="380" width="380" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="p3_12" value="12. Guard&#xa;FirebaseAuthGuard / RoleGuard / DoctorContextGuard / Ws guards&#xa;Bloquean entrada antes de la logica" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="2160" y="380" width="380" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="p3_13" value="13. Circuit Breaker&#xa;frontend/lib/httpClient.ts&#xa;Estados CLOSED / OPEN / HALF_OPEN" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="1320" y="560" width="380" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="p3_14" value="14. Retry + Exponential Backoff&#xa;frontend httpClient y consumer retry-policy.adapter.ts&#xa;Protege HTTP y mensajeria" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="1740" y="560" width="380" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="p3_15" value="15. Exception Filter&#xa;producer/infrastructure/filters/domain-exception.filter.ts&#xa;DomainError -&gt; HTTP 400" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="2160" y="560" width="380" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="p3_16" value="16. Interceptor AOP&#xa;producer/common/interceptors/audit.interceptor.ts&#xa;Auditoria cross-cutting y fire-and-forget" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="1320" y="740" width="380" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="p3_17" value="17. Distributed Lock&#xa;lock.repository + mongoose-lock.repository.ts&#xa;Evita mantenimiento concurrente" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="1740" y="740" width="380" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="p3_18" value="18. Optimistic Locking / Atomic CAS&#xa;DoctorWriteRepository.markBusyAtomic&#xa;Evita doble asignacion de medico" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="2160" y="740" width="380" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="p3_frontend_patterns" value="PATRONES FRONTEND&#xa;Composition Root -&gt; DependencyContext.tsx&#xa;Provider Pattern -&gt; AuthProvider, ThemeProvider, DependencyProvider&#xa;Custom Hook Pattern -&gt; useAuth, useProfiles, useQueuePosition, useOperationalMetrics y demas&#xa;Input Sanitization -&gt; security/sanitize.ts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacing=8;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="980" width="800" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="p3_ddd" value="DDD TACTICAL PACK&#xa;Entities -&gt; Appointment, Doctor&#xa;Value Objects -&gt; IdCard, FullName, Priority&#xa;Branded Types -&gt; branded.types.ts&#xa;Domain Events -&gt; AppointmentRegisteredEvent, AppointmentAssignedEvent&#xa;Domain Error Hierarchy -&gt; validation, duplicate, infrastructure&#xa;Read Models -&gt; appointment-view, doctor-view, profile-view" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacing=8;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="880" y="980" width="800" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="p3_solid" value="SOLID 5/5 APLICADO&#xa;SRP -&gt; cada use case y handler tiene una sola responsabilidad&#xa;OCP -&gt; event bus y handlers registrables, @Roles extensible&#xa;LSP -&gt; decorators y adapters respetan contratos&#xa;ISP -&gt; repositories read/write segregados y ports especializados&#xa;DIP -&gt; use cases dependen de puertos, no de concreciones" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;verticalAlign=top;spacing=8;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1720" y="980" width="820" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="p3_note" value="NOTA DE LECTURA&#xa;La pagina mezcla patrones estructurales, tacticos y de resiliencia porque todos aparecen en el codigo actual.&#xa;SPEC-003 impacta sobre todo Command, Domain Events, Policy, Repository, Data Mapper y Atomic CAS.&#xa;SPEC-004 impacta sobre todo Guard, Interceptor, Adapter de Firebase y Provider / Hook patterns en frontend." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d9ead3;strokeColor=#82b366;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="40" y="1300" width="2500" height="180" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
    <diagram id="delta-page" name="4. Delta por Feature SPEC-003 y SPEC-004">
        <mxGraphModel dx="1219" dy="738" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2600" pageHeight="1800" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="p4_title" value="DELTA POR FEATURE&#xa;Que se agrego o modifico con SPEC-003 y SPEC-004 sobre la base arquitectonica original" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1f2937;strokeColor=#111827;fontColor=#ffffff;fontStyle=1;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="20" y="20" width="2560" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="p4_t_base" value="BASE PREVIA&#xa;Frontend publico + Producer + Consumer + RabbitMQ + MongoDB&#xa;Cola de turnos, scheduler y realtime publico" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="40" y="110" width="560" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="p4_t_s003" value="SPEC-003&#xa;smart-appointment-management&#xa;Motor con medicos reales, queue position, doctor info y auditoria" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cfe2f3;strokeColor=#6c8ebf;fontStyle=1;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="680" y="110" width="560" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="p4_t_s004" value="SPEC-004&#xa;operational-access-foundation&#xa;Auth Firebase, profiles, roles y proteccion de modulos" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4cccc;strokeColor=#b85450;fontStyle=1;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="1320" y="110" width="560" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="p4_t_now" value="ESTADO ACTUAL DEL REPO&#xa;Se suman metricas, audit, offices, specialties, WS operativo y refinamientos posteriores" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d9ead3;strokeColor=#82b366;fontStyle=1;align=center;verticalAlign=middle;" parent="1" vertex="1">
                    <mxGeometry x="1960" y="110" width="580" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="p4_e1" value="" style="endArrow=classic;html=1;strokeColor=#666666;" parent="1" source="p4_t_base" target="p4_t_s003" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p4_e2" value="" style="endArrow=classic;html=1;strokeColor=#666666;" parent="1" source="p4_t_s003" target="p4_t_s004" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p4_e3" value="" style="endArrow=classic;html=1;strokeColor=#666666;" parent="1" source="p4_t_s004" target="p4_t_now" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="p4_spec003_bg" value="SPEC-003 - SMART APPOINTMENT MANAGEMENT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;align=center;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="40" y="260" width="1220" height="1300" as="geometry"/>
                </mxCell>
                <mxCell id="p4_s003_prod" value="PRODUCER / API DELTA&#xa;[NUEVO] doctors/doctor.module.ts y doctor.controller.ts&#xa;[NUEVO] GET /appointments/queue-position/:idCard&#xa;[NUEVO] publicacion de doctor_checked_in a turnos_queue&#xa;[MOD] AppointmentResponseDto y AppointmentEventPayload exponen doctorId y doctorName&#xa;[MOD] /appointments sigue siendo la puerta de entrada pero ahora el llamado puede resolver medico real" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="70" y="320" width="1160" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="p4_s003_cons" value="CONSUMER / DOMINIO Y WRITE SIDE&#xa;[NUEVO] Doctor schema + DoctorReadRepository&#xa;[NUEVO] AuditLog schema + adapter de auditoria&#xa;[MOD] assign-doctor.use-case.impl.ts reemplaza la asignacion limitada a offices abstractos&#xa;[MOD] Appointment entity guarda doctorId y doctorName&#xa;[MOD] ConsultationPolicy evoluciona para disponibilidad de medico y office asociado" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="70" y="560" width="1160" height="250" as="geometry"/>
                </mxCell>
                <mxCell id="p4_s003_front" value="FRONTEND / UX Y MODELOS NUEVOS&#xa;[NUEVO] domain/Doctor.ts y domain/QueuePosition.ts&#xa;[NUEVO] AssignmentNotification, QueuePositionBadge, DoctorInfo&#xa;[NUEVO] useQueuePosition&#xa;[NUEVO] doctorService y extension de appointmentService para queue-position&#xa;[MOD] CalledAppointmentCard y WaitingAppointmentCard muestran doctor, office y posicion" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="70" y="830" width="1160" height="240" as="geometry"/>
                </mxCell>
                <mxCell id="p4_s003_data" value="DATA Y MENSAJERIA&#xa;[NUEVO] doctors collection como entidad operativa consultada por el motor&#xa;[NUEVO] audit_logs para registrar decisiones de asignacion&#xa;[MOD] appointments documenta doctorId, doctorName y office derivado del medico&#xa;[NUEVO] doctor_checked_in activa asignacion reactiva sin esperar al scheduler" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="70" y="1090" width="1160" height="210" as="geometry"/>
                </mxCell>
                <mxCell id="p4_s003_business" value="IMPACTO FUNCIONAL DE SPEC-003&#xa;La cola deja de ser solo offices numericos y pasa a medicos reales disponibles.&#xa;El paciente conoce posicion en cola y medico asignado.&#xa;Las decisiones de asignacion quedan auditables y pueden emitirse por realtime." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d9ead3;strokeColor=#82b366;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="70" y="1320" width="1160" height="200" as="geometry"/>
                </mxCell>
                <mxCell id="p4_spec004_bg" value="SPEC-004 - OPERATIONAL ACCESS FOUNDATION" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;align=center;verticalAlign=top;" parent="1" vertex="1">
                    <mxGeometry x="1340" y="260" width="1220" height="1300" as="geometry"/>
                </mxCell>
                <mxCell id="p4_s004_prod" value="PRODUCER / AUTH Y PERFILES&#xa;[NUEVO] auth.controller.ts y POST /auth/session&#xa;[NUEVO] profiles.controller.ts + profiles.module.ts + CRUD admin-only&#xa;[NUEVO] FirebaseAuthGuard, FirebaseTokenOnlyGuard, RoleGuard, DoctorContextGuard, WsFirebaseAuthGuard&#xa;[MOD] POST /appointments, /metrics, /audit-logs, /offices, /specialties y doctor endpoints se protegen por rol y contexto" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="1370" y="320" width="1160" height="260" as="geometry"/>
                </mxCell>
                <mxCell id="p4_s004_front" value="FRONTEND / ACCESO OPERATIVO&#xa;[NUEVO] LoginForm, RoleGate, ProfileFormModal&#xa;[NUEVO] AuthProvider, useAuth, useProfiles, useRoleGuard&#xa;[NUEVO] paginas /login y /admin/profiles&#xa;[MOD] navegacion y visibilidad de modulos segun rol&#xa;[MOD] servicios protegidos envian Bearer token y consumen Profile operativo" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="1370" y="600" width="1160" height="240" as="geometry"/>
                </mxCell>
                <mxCell id="p4_s004_identity" value="IDENTIDAD Y DATOS&#xa;[NUEVO] profiles collection / Profile model&#xa;[NUEVO] integracion Firebase Auth en frontend y verificacion por Admin SDK en backend&#xa;[MOD] el sistema deja de ser anonimo para el personal interno&#xa;[MOD] el doctor solo puede operar su propio doctor_id" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="1370" y="860" width="1160" height="210" as="geometry"/>
                </mxCell>
                <mxCell id="p4_s004_flows" value="FLUJOS HABILITADOS POR SPEC-004&#xa;Solo admin y recepcionista pueden registrar y cancelar turnos.&#xa;Solo admin puede gestionar perfiles, metrics, audit, offices y specialties.&#xa;Doctor puede check-in/check-out y completar citas solo en su contexto.&#xa;La pantalla publica y dashboard publico se mantienen abiertos para no romper la demo ni la operacion publica." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="1370" y="1090" width="1160" height="230" as="geometry"/>
                </mxCell>
                <mxCell id="p4_s004_business" value="IMPACTO FUNCIONAL DE SPEC-004&#xa;Introduce trazabilidad, identidad operativa y control de acceso por rol.&#xa;Convierte el sistema en producto utilizable por personal interno, no solo demo tecnica.&#xa;El frontend y el Producer quedan alineados alrededor de Profile activo + permisos." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d9ead3;strokeColor=#82b366;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="1370" y="1340" width="1160" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="p4_current_modules" value="MODULOS ACTUALES COMPLEMENTARIOS EN EL ESTADO DEL REPO&#xa;[ACTUAL] metrics/, audit/, offices/, specialties/, operational-appointments.gateway, doctor dashboard UI, office catalog UI, specialties UI, authenticated websocket channel y refinamientos de privacidad / navegacion.&#xa;Estos modulos son parte de la arquitectura actual, pero no se marcan aqui como delta principal porque no pertenecen al nucleo original de SPEC-003 o SPEC-004." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;verticalAlign=top;spacing=8;" parent="1" vertex="1">
                    <mxGeometry x="40" y="1590" width="2520" height="150" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
