                <mxCell id="person_patient" value="Paciente / Visitante&#xa;&#xa;Consulta su turno en la&#xa;pantalla de la sala de espera.&#xa;No requiere cuenta." style="shape=mxgraph.c4.person2;whiteSpace=wrap;html=1;container=0;fontSize=11;fontColor=#ffffff;fillColor=#08427B;strokeColor=#052E56;align=center;" parent="1" vertex="1">
                    <mxGeometry x="180" y="270" width="200" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="person_recep" value="Recepcionista&#xa;&#xa;Registra pacientes&#xa;con nivel de urgencia.&#xa;Cancela turnos si es necesario." style="shape=mxgraph.c4.person2;whiteSpace=wrap;html=1;container=0;fontSize=11;fontColor=#ffffff;fillColor=#08427B;strokeColor=#052E56;align=center;" parent="1" vertex="1">
                    <mxGeometry x="440" y="270" width="200" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="person_doctor" value="Medico&#xa;&#xa;Llega a su consultorio (check-in),&#xa;atiende pacientes asignados&#xa;y se retira (check-out)." style="shape=mxgraph.c4.person2;whiteSpace=wrap;html=1;container=0;fontSize=11;fontColor=#ffffff;fillColor=#08427B;strokeColor=#052E56;align=center;" parent="1" vertex="1">
                    <mxGeometry x="700" y="270" width="200" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="person_admin" value="Administrador&#xa;&#xa;Gestiona personal, perfiles,&#xa;consultorios y supervisa&#xa;metricas y auditoria." style="shape=mxgraph.c4.person2;whiteSpace=wrap;html=1;container=0;fontSize=11;fontColor=#ffffff;fillColor=#08427B;strokeColor=#052E56;align=center;" parent="1" vertex="1">
                    <mxGeometry x="960" y="270" width="200" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="fe_container" value="Portal Web de la Clinica&#xa;[Contenedor: Next.js + React · Puerto 3001]&#xa;&#xa;Interfaz web que usan pacientes, recepcionistas, medicos y administradores para interactuar con el sistema de turnos." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#3C7FC0;fontColor=#ffffff;fontStyle=1;fontSize=12;verticalAlign=top;align=center;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="40" y="500" width="1180" height="680" as="geometry"/>
                </mxCell>
                <mxCell id="fe_public_screen" value="Pantalla Publica de Espera&#xa;&#xa;Muestra en tiempo real la cola de&#xa;turnos: quienes esperan y quienes&#xa;estan siendo atendidos. Visible&#xa;en la TV de la sala de espera." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3B6FA0;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="70" y="600" width="250" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="fe_registration" value="Panel de Registro de Turnos&#xa;&#xa;La recepcionista ingresa nombre,&#xa;cedula y urgencia del paciente.&#xa;El turno entra a la cola." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="350" y="600" width="250" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="fe_doctor_panel" value="Panel del Medico&#xa;&#xa;El doctor marca su llegada,&#xa;ve al paciente asignado,&#xa;finaliza la atencion y&#xa;se retira al terminar su jornada." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3B6FA0;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="630" y="600" width="250" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="fe_admin" value="Panel de Administracion&#xa;&#xa;Gestion de perfiles y roles,&#xa;catalogo de consultorios&#xa;y especialidades, metricas&#xa;operativas y auditoria." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3B6FA0;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="910" y="600" width="250" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="fe_queue_badge" value="[NUEVO] Indicador de&#xa;Posicion en Cola&#xa;&#xa;El paciente ve su lugar&#xa;en la fila: Posicion 3 de 7." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B7E1CD;strokeColor=#34A853;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="70" y="770" width="200" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="fe_assignment_notif" value="[NUEVO] Notificacion&#xa;de Llamado&#xa;&#xa;Alerta cuando el paciente&#xa;es asignado a un medico:&#xa;nombre, consultorio y hora." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B7E1CD;strokeColor=#34A853;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="300" y="770" width="200" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="fe_doctor_info" value="[NUEVO] Informacion del&#xa;Medico Asignado&#xa;&#xa;Muestra el nombre del doctor&#xa;y el consultorio al que debe&#xa;dirigirse el paciente." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B7E1CD;strokeColor=#34A853;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="530" y="770" width="200" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="fe_login" value="Inicio de Sesion&#xa;&#xa;El personal interno ingresa&#xa;sus credenciales para&#xa;acceder a los modulos&#xa;segun su rol." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3B6FA0;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="760" y="770" width="200" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="fe_realtime" value="Conexion en Tiempo Real&#xa;&#xa;Recibe actualizacion instantanea&#xa;cada vez que un turno cambia&#xa;de estado. Reconecta&#xa;automaticamente si se pierde." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="990" y="770" width="200" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="fe_auth_state" value="Gestion de Identidad&#xa;&#xa;Mantiene la sesion del&#xa;usuario y determina que&#xa;modulos puede ver&#xa;segun su rol." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3B6FA0;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="70" y="930" width="200" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="fe_http" value="Comunicacion con el Servidor&#xa;&#xa;Envia y recibe datos de la API.&#xa;Protege contra fallos en cascada&#xa;con reintentos automaticos." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3B6FA0;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="300" y="930" width="200" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="fe_sanitize" value="Proteccion de Datos de Entrada&#xa;&#xa;Limpia la informacion que&#xa;ingresa el usuario para&#xa;prevenir ataques." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3B6FA0;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="530" y="930" width="200" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="prod_container" value="Puerta de Entrada de la Clinica&#xa;[Contenedor: NestJS API · Puerto 3000]&#xa;&#xa;Recibe todas las solicitudes del portal web, valida identidad y permisos, y coordina el flujo de operaciones. Sirve datos en tiempo real." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#3C7FC0;fontColor=#ffffff;fontStyle=1;fontSize=12;verticalAlign=top;align=center;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="1300" y="500" width="1260" height="680" as="geometry"/>
                </mxCell>
                <mxCell id="prod_appointment_intake" value="Recepcion de Turnos&#xa;&#xa;Recibe la solicitud de registro,&#xa;valida los datos del paciente&#xa;(nombre, cedula, urgencia) y&#xa;la envia al procesamiento." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="1330" y="600" width="230" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="prod_queue_query" value="Consulta de Turnos&#xa;&#xa;Permite ver el estado de todos&#xa;los turnos del dia: quienes&#xa;esperan, quienes estan siendo&#xa;atendidos, completados." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="1590" y="600" width="230" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="prod_doctor_mgmt" value="[NUEVO] Gestion de Medicos&#xa;&#xa;Alta de medicos, control de&#xa;llegada (check-in) y salida&#xa;(check-out) del consultorio.&#xa;Informa la disponibilidad." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B7E1CD;strokeColor=#34A853;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="1850" y="600" width="230" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="prod_queue_position" value="[NUEVO] Consulta de&#xa;Posicion en Cola&#xa;&#xa;Informa al paciente en que&#xa;lugar de la fila se encuentra&#xa;y cuantos hay antes que el." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B7E1CD;strokeColor=#34A853;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="2110" y="600" width="230" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="prod_auth" value="Verificacion de Identidad&#xa;&#xa;Comprueba que el usuario sea&#xa;quien dice ser validando&#xa;su credencial con el servicio&#xa;de identidad externo." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3B6FA0;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="1330" y="770" width="230" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="prod_permissions" value="Control de Permisos&#xa;&#xa;Solo permite acciones segun&#xa;el rol: admin gestiona todo,&#xa;recepcion registra turnos,&#xa;doctor opera su consultorio." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3B6FA0;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="1590" y="770" width="230" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="prod_realtime_broadcast" value="Difusion en Tiempo Real&#xa;&#xa;Envia actualizaciones instantaneas&#xa;a todas las pantallas conectadas&#xa;cada vez que cambia un turno.&#xa;Canal publico y canal operativo." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="1850" y="770" width="230" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="prod_lifecycle" value="Ciclo de Vida de Turnos&#xa;&#xa;Permite completar y cancelar&#xa;turnos, validando que solo&#xa;se haga en el estado correcto&#xa;y por quien tiene permiso." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3B6FA0;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="2110" y="770" width="230" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="prod_profiles" value="Gestion de Perfiles&#xa;&#xa;El admin da de alta usuarios,&#xa;asigna roles (recepcionista,&#xa;doctor, admin) y vincula&#xa;al doctor con su registro medico." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3B6FA0;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="1330" y="930" width="230" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="prod_metrics" value="Metricas Operativas&#xa;&#xa;Indicadores del dia: total de&#xa;turnos, tiempos de espera,&#xa;medicos activos, consultorios&#xa;en uso, turnos cancelados." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3B6FA0;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="1590" y="930" width="230" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="prod_audit" value="Registro de Actividad&#xa;&#xa;Historial de quien hizo que&#xa;y cuando: creacion de perfiles,&#xa;cancelaciones, check-in y&#xa;check-out de doctores." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3B6FA0;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="1850" y="930" width="230" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="prod_offices_spec" value="Catalogo Operativo&#xa;&#xa;Gestion de consultorios&#xa;(habilitar, deshabilitar,&#xa;ajustar capacidad) y&#xa;catalogo de especialidades." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3B6FA0;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="2110" y="930" width="230" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="cons_container" value="Motor de Operacion de la Clinica&#xa;[Contenedor: NestJS Worker · Sin puerto publico]&#xa;&#xa;Ejecuta la logica de negocio: procesa turnos, asigna medicos segun urgencia y disponibilidad, audita decisiones y notifica cambios. Opera de forma autonoma." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#438DD5;strokeColor=#3C7FC0;fontColor=#ffffff;fontStyle=1;fontSize=12;verticalAlign=top;align=center;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="2640" y="500" width="1520" height="680" as="geometry"/>
                </mxCell>
                <mxCell id="cons_register" value="Registro de Pacientes en Cola&#xa;&#xa;Recibe al paciente, valida que&#xa;no tenga un turno activo,&#xa;lo registra como &#39;en espera&#39;&#xa;y dispara la asignacion." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3B6FA0;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="2670" y="600" width="240" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="cons_assign_doctor" value="[NUEVO] Motor Inteligente&#xa;de Asignacion&#xa;&#xa;Empareja al paciente con el&#xa;medico disponible mas adecuado.&#xa;Prioriza por urgencia (Alta&#xa;antes que Media y Baja),&#xa;despues por orden de llegada." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B7E1CD;strokeColor=#34A853;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="2940" y="600" width="240" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="cons_reactive" value="[NUEVO] Reaccion Inmediata&#xa;a Llegada de Medico&#xa;&#xa;Cuando un doctor llega a su&#xa;consultorio, busca pacientes&#xa;en espera y los asigna al&#xa;instante sin esperar al ciclo." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B7E1CD;strokeColor=#34A853;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="3210" y="600" width="240" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="cons_complete" value="Finalizacion de Atencion&#xa;&#xa;Marca el turno como completado&#xa;cuando el doctor termina la&#xa;consulta. Libera al medico&#xa;para atender al siguiente." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="3480" y="600" width="240" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="cons_cancel" value="Cancelacion de Turnos&#xa;&#xa;Retira un turno de la cola&#xa;de espera. Solo se puede&#xa;cancelar si el paciente&#xa;aun no fue llamado." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3B6FA0;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="3750" y="600" width="240" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="cons_release" value="[NUEVO] Liberacion&#xa;Automatica de Medicos&#xa;&#xa;Cuando una consulta expira&#xa;o se completa, el medico&#xa;vuelve a estar disponible&#xa;automaticamente." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B7E1CD;strokeColor=#34A853;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="2670" y="790" width="240" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="cons_scheduler" value="Programador Periodico&#xa;&#xa;Cada 10 segundos revisa si&#xa;hay pacientes esperando y&#xa;medicos disponibles. Ejecuta&#xa;asignacion y limpieza." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3B6FA0;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="2940" y="790" width="240" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="cons_audit" value="[NUEVO] Auditoria de&#xa;Decisiones Clinicas&#xa;&#xa;Registra cada asignacion con&#xa;contexto completo: medico,&#xa;paciente, consultorio, urgencia&#xa;y posicion que tenia en la cola." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B7E1CD;strokeColor=#34A853;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="3210" y="790" width="240" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="cons_notify" value="Notificacion de Cambios&#xa;&#xa;Cada vez que un turno cambia&#xa;de estado, publica el evento&#xa;para que la Puerta de Entrada&#xa;lo difunda en tiempo real." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3B6FA0;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="3480" y="790" width="240" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="cons_domain_rules" value="Reglas de Negocio&#xa;&#xa;Solo medicos disponibles&#xa;reciben pacientes. Un paciente&#xa;solo tiene un turno activo.&#xa;Urgencia Alta tiene prioridad&#xa;absoluta sobre Media y Baja." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="3750" y="790" width="240" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="cons_resilience" value="Proteccion contra Fallos&#xa;&#xa;Si el sistema de mensajeria&#xa;falla, los turnos no se pierden.&#xa;Reintentos automaticos y cola&#xa;de mensajes fallidos (DLQ)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3B6FA0;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="2670" y="960" width="240" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="cons_lock" value="Prevencion de Conflictos&#xa;&#xa;Asegura que dos procesos no&#xa;asignen al mismo medico&#xa;simultaneamente. Bloqueo&#xa;atomico por medico." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#85BBF0;strokeColor=#3B6FA0;fontColor=#1a1a1a;fontSize=10;align=center;" parent="1" vertex="1">
                    <mxGeometry x="2940" y="960" width="240" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="ext_firebase" value="Servicio de Identidad&#xa;[Sistema externo: Firebase Auth]&#xa;&#xa;Emite y valida credenciales&#xa;del personal interno de la clinica." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#999999;strokeColor=#666666;fontColor=#ffffff;fontStyle=1;fontSize=11;align=center;" parent="1" vertex="1">
                    <mxGeometry x="40" y="1340" width="350" height="140" as="geometry"/>
