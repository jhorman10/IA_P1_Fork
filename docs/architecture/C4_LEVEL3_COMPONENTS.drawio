                <mxCell id="note_cqrs" value="PATRON CQRS&#xa;La Puerta de Entrada (Producer) solo LEE datos y ENVIA ordenes.&#xa;El Motor de Operacion (Consumer) EJECUTA la logica y ESCRIBE los resultados.&#xa;Esta separacion permite que la pantalla publica sea rapida y el procesamiento sea confiable." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=18;fillColor=#FFF9C4;strokeColor=#D6B656;align=left;verticalAlign=top;spacing=8;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="40" y="1560" width="520" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="note_event" value="COMUNICACION ASINCRONA&#xa;El Producer no espera respuesta: deja la orden en la Cola de Mensajes y responde &#39;Recibido&#39;.&#xa;El Consumer la procesa cuando puede, y avisa cuando termina.&#xa;Si falla, el mensaje va a la Cola de Fallidos para revision manual." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=18;fillColor=#FFF9C4;strokeColor=#D6B656;align=left;verticalAlign=top;spacing=8;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="600" y="1560" width="520" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="note_spec003" value="FEATURE: SPEC-003 SMART APPOINTMENT MANAGEMENT&#xa;Antes: el sistema asignaba pacientes a consultorios numericos vacios (1 al 5).&#xa;Ahora: el Motor Inteligente empareja pacientes con medicos reales segun urgencia y disponibilidad.&#xa;El paciente sabe su posicion en la fila, recibe notificacion con nombre del doctor y consultorio,&#xa;y cada decision de asignacion queda auditada con contexto clinico completo." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=18;fillColor=#E8F5E9;strokeColor=#34A853;align=left;verticalAlign=top;spacing=8;fontSize=10;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="2480" y="1560" width="520" height="130" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
