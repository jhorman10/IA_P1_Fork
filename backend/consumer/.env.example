# ⚕️ HUMAN CHECK - Example Environment Variables (Consumer)
# Secrets must be kept out of version control.
# Copy this file to .env and fill in your values.

PORT=3000
MONGODB_URI=mongodb://root:example@localhost:27017/appointments?authSource=admin
RABBITMQ_URL=amqp://user:password@localhost:5672
RABBITMQ_QUEUE=appointments_queue
RABBITMQ_NOTIFICATIONS_QUEUE=notifications_queue
DLX_EXCHANGE=appointment_dlx
DLX_ROUTING_KEY=appointment_dlq


# Retry Policy
MAX_RETRIES=2

# Scheduler Settings
SCHEDULER_INTERVAL_MS=5000
