# ⚕️ HUMAN CHECK - Example Environment Variables (Consumer)
# Secrets must be kept out of version control.
# Copy this file to .env and fill in your values.


PORT=3000
MONGODB_URI=mongodb://sofka_admin:sofka_secure_pass_456@localhost:27017/appointments_db?authSource=admin
RABBITMQ_URL=amqp://sofka_user:sofka_password123@localhost:5672
RABBITMQ_QUEUE=turnos_queue
RABBITMQ_NOTIFICATIONS_QUEUE=turnos_notifications
DLX_EXCHANGE=appointment_dlx
DLX_ROUTING_KEY=appointment_dlq


# Retry Policy
MAX_RETRIES=2

# Scheduler Settings
SCHEDULER_INTERVAL_MS=5000
